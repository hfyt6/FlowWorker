{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "search_text_request": {
      "type": "object",
      "properties": {
        "text": {
          "type": "string",
          "description": "要搜索的文本内容"
        },
        "pattern": {
          "type": "string",
          "description": "搜索模式（正则表达式）"
        },
        "case_sensitive": {
          "type": "boolean",
          "default": true,
          "description": "是否区分大小写"
        },
        "max_results": {
          "type": "integer",
          "default": 100,
          "minimum": 1,
          "description": "最大返回结果数"
        }
      },
      "required": ["text", "pattern"]
    },
    "search_text_response": {
      "type": "object",
      "properties": {
        "matches": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/match_info"
          }
        },
        "total_count": {
          "type": "integer"
        }
      }
    },
    "match_info": {
      "type": "object",
      "properties": {
        "index": {
          "type": "integer",
          "description": "匹配起始位置"
        },
        "length": {
          "type": "integer",
          "description": "匹配长度"
        },
        "value": {
          "type": "string",
          "description": "匹配的文本值"
        },
        "line_number": {
          "type": "integer",
          "description": "所在行号（从1开始）"
        },
        "column": {
          "type": "integer",
          "description": "所在列号（从1开始）"
        },
        "groups": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "index": { "type": "integer" },
              "length": { "type": "integer" },
              "value": { "type": "string" },
              "name": { "type": "string" }
            }
          },
          "description": "捕获组信息"
        }
      }
    },
    "replace_text_request": {
      "type": "object",
      "properties": {
        "text": {
          "type": "string",
          "description": "原始文本内容"
        },
        "pattern": {
          "type": "string",
          "description": "要替换的模式"
        },
        "replacement": {
          "type": "string",
          "description": "替换后的文本"
        },
        "is_regex": {
          "type": "boolean",
          "default": false,
          "description": "是否使用正则表达式"
        },
        "replace_all": {
          "type": "boolean",
          "default": true,
          "description": "是否替换所有匹配项"
        }
      },
      "required": ["text", "pattern", "replacement"]
    },
    "replace_text_response": {
      "type": "object",
      "properties": {
        "result": {
          "type": "string",
          "description": "替换后的文本"
        },
        "replacements_count": {
          "type": "integer",
          "description": "替换次数"
        }
      }
    },
    "count_lines_request": {
      "type": "object",
      "properties": {
        "text": {
          "type": "string",
          "description": "要统计的文本内容"
        },
        "include_empty": {
          "type": "boolean",
          "default": true,
          "description": "是否包含空行"
        }
      },
      "required": ["text"]
    },
    "count_lines_response": {
      "type": "object",
      "properties": {
        "total_lines": {
          "type": "integer",
          "description": "总行数"
        },
        "non_empty_lines": {
          "type": "integer",
          "description": "非空行数"
        },
        "empty_lines": {
          "type": "integer",
          "description": "空行数"
        },
        "character_count": {
          "type": "integer",
          "description": "字符总数"
        },
        "word_count": {
          "type": "integer",
          "description": "单词总数"
        }
      }
    },
    "format_json_request": {
      "type": "object",
      "properties": {
        "json_string": {
          "type": "string",
          "description": "要格式化的JSON字符串"
        },
        "indent_size": {
          "type": "integer",
          "default": 2,
          "minimum": 0,
          "maximum": 8,
          "description": "缩进空格数"
        },
        "sort_keys": {
          "type": "boolean",
          "default": false,
          "description": "是否对键进行排序"
        }
      },
      "required": ["json_string"]
    },
    "format_json_response": {
      "type": "object",
      "properties": {
        "formatted": {
          "type": "string",
          "description": "格式化后的JSON字符串"
        },
        "is_valid": {
          "type": "boolean",
          "description": "JSON是否有效"
        }
      }
    },
    "validate_json_request": {
      "type": "object",
      "properties": {
        "json_string": {
          "type": "string",
          "description": "要验证的JSON字符串"
        }
      },
      "required": ["json_string"]
    },
    "validate_json_response": {
      "type": "object",
      "properties": {
        "is_valid": {
          "type": "boolean",
          "description": "JSON是否有效"
        },
        "error": {
          "type": "string",
          "description": "错误信息（如果无效）"
        },
        "error_position": {
          "type": "integer",
          "description": "错误位置（字符索引）"
        },
        "error_line": {
          "type": "integer",
          "description": "错误所在行号"
        },
        "error_column": {
          "type": "integer",
          "description": "错误所在列号"
        }
      }
    }
  }
}
