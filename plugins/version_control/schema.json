{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "git_status_request": {
      "type": "object",
      "properties": {
        "repository_path": {
          "type": "string",
          "minLength": 1,
          "description": "Git仓库路径"
        }
      },
      "required": ["repository_path"]
    },
    "git_status_response": {
      "type": "object",
      "properties": {
        "branch": {
          "type": "string",
          "description": "当前分支名称"
        },
        "is_clean": {
          "type": "boolean",
          "description": "工作区是否干净"
        },
        "modified": {
          "type": "array",
          "description": "已修改但未暂存的文件列表",
          "items": {
            "type": "object",
            "properties": {
              "path": { "type": "string" },
              "status": { "type": "string" }
            }
          }
        },
        "staged": {
          "type": "array",
          "description": "已暂存的文件列表",
          "items": {
            "type": "object",
            "properties": {
              "path": { "type": "string" },
              "status": { "type": "string" }
            }
          }
        },
        "untracked": {
          "type": "array",
          "description": "未跟踪的文件列表",
          "items": { "type": "string" }
        },
        "deleted": {
          "type": "array",
          "description": "已删除的文件列表",
          "items": { "type": "string" }
        },
        "renamed": {
          "type": "array",
          "description": "重命名的文件列表",
          "items": {
            "type": "object",
            "properties": {
              "old_path": { "type": "string" },
              "new_path": { "type": "string" }
            }
          }
        },
        "ahead": {
          "type": "integer",
          "description": "领先远程分支的提交数"
        },
        "behind": {
          "type": "integer",
          "description": "落后远程分支的提交数"
        }
      }
    },
    "git_diff_request": {
      "type": "object",
      "properties": {
        "repository_path": {
          "type": "string",
          "minLength": 1,
          "description": "Git仓库路径"
        },
        "commit1": {
          "type": "string",
          "description": "第一个提交哈希或引用"
        },
        "commit2": {
          "type": "string",
          "description": "第二个提交哈希或引用"
        },
        "file_path": {
          "type": "string",
          "description": "指定文件路径"
        },
        "cached": {
          "type": "boolean",
          "default": false,
          "description": "是否比较暂存区与HEAD"
        }
      },
      "required": ["repository_path"]
    },
    "git_diff_response": {
      "type": "object",
      "properties": {
        "diff": {
          "type": "string",
          "description": "差异内容"
        },
        "files_changed": {
          "type": "array",
          "description": "变更的文件列表",
          "items": {
            "type": "object",
            "properties": {
              "path": { "type": "string" },
              "change_type": { "type": "string" },
              "insertions": { "type": "integer" },
              "deletions": { "type": "integer" }
            }
          }
        },
        "insertions": {
          "type": "integer",
          "description": "总行数增加"
        },
        "deletions": {
          "type": "integer",
          "description": "总行数删除"
        }
      }
    },
    "git_log_request": {
      "type": "object",
      "properties": {
        "repository_path": {
          "type": "string",
          "minLength": 1,
          "description": "Git仓库路径"
        },
        "limit": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1000,
          "default": 20,
          "description": "返回的提交数量限制"
        },
        "branch": {
          "type": "string",
          "description": "指定分支"
        },
        "author": {
          "type": "string",
          "description": "按作者过滤"
        },
        "since": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
          "description": "起始日期，格式：YYYY-MM-DD"
        },
        "until": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
          "description": "结束日期，格式：YYYY-MM-DD"
        },
        "file_path": {
          "type": "string",
          "description": "指定文件路径"
        }
      },
      "required": ["repository_path"]
    },
    "git_log_response": {
      "type": "object",
      "properties": {
        "commits": {
          "type": "array",
          "description": "提交记录列表",
          "items": {
            "type": "object",
            "properties": {
              "hash": { "type": "string" },
              "short_hash": { "type": "string" },
              "message": { "type": "string" },
              "author": { "type": "string" },
              "email": { "type": "string" },
              "date": { "type": "string" },
              "timestamp": { "type": "integer" },
              "files_changed": { "type": "integer" },
              "insertions": { "type": "integer" },
              "deletions": { "type": "integer" }
            }
          }
        },
        "total_count": {
          "type": "integer",
          "description": "总提交数"
        }
      }
    },
    "git_branch_request": {
      "type": "object",
      "properties": {
        "repository_path": {
          "type": "string",
          "minLength": 1,
          "description": "Git仓库路径"
        },
        "action": {
          "type": "string",
          "enum": ["list", "create", "switch", "delete"],
          "description": "操作类型"
        },
        "branch_name": {
          "type": "string",
          "description": "分支名称"
        },
        "base_branch": {
          "type": "string",
          "description": "基于哪个分支创建"
        },
        "force": {
          "type": "boolean",
          "default": false,
          "description": "是否强制删除"
        }
      },
      "required": ["repository_path", "action"]
    },
    "git_branch_response": {
      "type": "object",
      "properties": {
        "current_branch": {
          "type": "string",
          "description": "当前分支名称"
        },
        "branches": {
          "type": "array",
          "description": "分支列表",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "is_current": { "type": "boolean" },
              "is_remote": { "type": "boolean" },
              "remote_name": { "type": "string" },
              "last_commit": { "type": "string" }
            }
          }
        },
        "success": {
          "type": "boolean",
          "description": "操作是否成功"
        },
        "message": {
          "type": "string",
          "description": "操作结果消息"
        }
      }
    },
    "git_commit_request": {
      "type": "object",
      "properties": {
        "repository_path": {
          "type": "string",
          "minLength": 1,
          "description": "Git仓库路径"
        },
        "message": {
          "type": "string",
          "minLength": 1,
          "description": "提交信息"
        },
        "files": {
          "type": "array",
          "description": "要提交的文件列表",
          "items": { "type": "string" }
        },
        "all": {
          "type": "boolean",
          "default": false,
          "description": "是否自动暂存所有修改的文件"
        },
        "amend": {
          "type": "boolean",
          "default": false,
          "description": "是否修改上一次提交"
        }
      },
      "required": ["repository_path", "message"]
    },
    "git_commit_response": {
      "type": "object",
      "properties": {
        "success": {
          "type": "boolean",
          "description": "提交是否成功"
        },
        "commit_hash": {
          "type": "string",
          "description": "提交哈希"
        },
        "message": {
          "type": "string",
          "description": "提交信息"
        },
        "files_committed": {
          "type": "array",
          "description": "已提交的文件列表",
          "items": { "type": "string" }
        }
      }
    }
  }
}
